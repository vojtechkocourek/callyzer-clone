# Copy this file to .env.local for local development. On Vercel, set
# the same variables in Project Settings → Environment Variables.

# Postgres connection string. Use the POOLED URL from Neon for Vercel.
# Looks like: postgresql://user:pass@ep-xxxx-pooler.region.neon.tech/dbname?sslmode=require
DATABASE_URL=

# Used by the seed script to create the very first admin login.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-please
